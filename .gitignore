# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next.bak/
/out/

# production
/build

# misc
.DS_Store
*.pem
core.*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# WhatsApp sessie-bestanden (bevatten authenticatiedata, nooit in git)
whatsapp-session/
.wwebjs_auth/
.wwebjs_cache/

# Upload bestanden (bewijs-foto's en video's, lokale opslag)
/uploads/

# Database bestanden (bevatten gebruikersdata, nooit in git)
*.db
*.db-shm
*.db-wal
